## Salary Calculation System
# Base class
class Employee:
    def calculate_salary(self):
        pass


# Subclass 1
class FullTimeEmployee(Employee):
    def __init__(self, salary):
        self.salary = salary

    def calculate_salary(self):
        return self.salary

# Subclass 2
class PartTimeEmployee(Employee):
    def __init__(self, hourly_rate, hours):
        self.hourly_rate = hourly_rate
        self.hours = hours

    def calculate_salary(self):
        return self.hourly_rate * self.hours

# Subclass 3
class Intern(Employee):
    def __init__(self, stipend):
        self.stipend = stipend

    def calculate_salary(self):
        return self.stipend

# Polymorphism (same method call, different behavior)
employees = [
    FullTimeEmployee(50000),
    PartTimeEmployee(500, 20),
    Intern(15000)
]

for emp in employees:
    print("Salary:", emp.calculate_salary())
# Discount System (Calculation Based)
class Customer:
    def get_discount(self, amount):
        self.amount=amount
        return amount
class Regularcustomer(Customer):
    def get_discount(self, amount):
        return amount -(amount*0.05)
class Permiumcustomer(Customer):
    def get_discount(self, amount):
        return amount - (amount*0.10)
class VIPcustomer(Customer):
    def get_discount(self, amount):
        return amount - (amount*0.20)
# creating object:
amount=10000
r =Regularcustomer()
p = Permiumcustomer()
v = VIPcustomer()
print(r.get_discount(amount))
print(p.get_discount(amount))
print(v.get_discount(amount))
## Banking Withdrawal System
# Base class
class Account:
    def withdraw(self, amount):
        pass


# Subclass 1
class SavingsAccount(Account):
    def withdraw(self, amount):
        fee = amount * 0.02
        total = amount + fee
        print(f"Savings Account: Withdraw {amount} with 2% fee = {total}")


# Subclass 2
class CurrentAccount(Account):
    def withdraw(self, amount):
        print(f"Current Account: Withdraw {amount} with no fee = {amount}")


# Subclass 3
class BusinessAccount(Account):
    def withdraw(self, amount):
        fee = amount * 0.05
        total = amount + fee
        print(f"Business Account: Withdraw {amount} with 5% fee = {total}")


# Creating objects
acc1 = SavingsAccount()
acc2 = CurrentAccount()
acc3 = BusinessAccount()

# Calling method (polymorphism, no loop)
acc1.withdraw(10000)
acc2.withdraw(10000)
acc3.withdraw(10000)
