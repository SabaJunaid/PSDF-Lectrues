# Animal Sounds (Method Overriding)

class Animal:
    def sound(self):
        print("Animal makes a sound")

class Dog(Animal):
    def sound(self):
        super().sound()
        print("Dog says: Woof Woof")

class Cat(Animal):
    def sound(self):
        super().sound()
        print("Cat says: Meow")
class Cow(Animal):
    def sound(self):
        super().sound()
        print("Cow says: Moo")
# Creating objects
d = Dog()
c = Cat()
w = Cow()

d.sound()
c.sound()
w.sound()
